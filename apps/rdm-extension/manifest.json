{
  "manifest_version": 3,
  "name": "RDM Downloader",
  "version": "0.1.0",
  "description": "把浏览器下载交给 RDM 桌面端处理。拦截下载或在右键菜单中调用 RDM。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "RDM 下载管理器"
  },
  "background": {
    "type": "module",
    "service_worker": "src/background.js"
  },
  "permissions": ["downloads", "storage", "contextMenus", "notifications"],
  "host_permissions": ["http://127.0.0.1:43721/"],
  "options_ui": {
    "page": "src/popup.html",
    "open_in_tab": false
  }
}
