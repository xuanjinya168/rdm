{
  "name": "rdm-desktop",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --fail-on-warnings",
    "test": "node --test",
    "preview": "vite preview",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build --no-bundle",
    "app:bundle": "tauri build",
    "smoke:server": "node ../../tools/smoke-server.mjs",
    "smoke:exe": "node ../../tools/exe-smoke.mjs",
    "smoke:bundle": "node ../../tools/bundle-smoke.mjs",
    "tools:check": "node --check ../../tools/check-version.mjs && node --check ../../tools/smoke-server.mjs && node --check ../../tools/exe-smoke.mjs && node --check ../../tools/bundle-smoke.mjs",
    "version:check": "node ../../tools/check-version.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4",
    "@tauri-apps/cli": "^2",
    "svelte": "^5",
    "svelte-check": "^4.6.0",
    "vite": "^5",
    "ws": "^8.21.0"
  }
}
